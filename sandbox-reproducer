#!/usr/bin/env bash
set -euo pipefail

# --- Configuration ---
BASE_IMAGE="${TART_BASE_IMAGE:-reproducer-base}"
SSH_KEY="${SSH_KEY:-$HOME/.ssh/id_ed25519.pub}"
VM_USER="admin"
VM_PASSWORD="admin"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

# --- Usage ---
usage() {
    cat <<EOF
Usage: $(basename "$0") <repo-url>

Clone a git repo into an isolated Tart VM and open it in IntelliJ via Gateway.

Prerequisites:
  brew install cirruslabs/cli/tart

Create a base image (one-time):
  tart clone ghcr.io/cirruslabs/ubuntu:latest reproducer-base
  tart run reproducer-base
  # Inside the VM: sudo apt-get update && sudo apt-get install -y openjdk-21-jdk maven git
  # Then shut down the VM

Environment variables:
  TART_BASE_IMAGE   Base VM image to clone (default: reproducer-base)
  SSH_KEY           Public key to install (default: ~/.ssh/id_ed25519.pub)
EOF
    exit 1
}

if [[ $# -ne 1 ]]; then
    usage
fi

# --- Dependency checks ---
if ! command -v tart &>/dev/null; then
    echo "Error: 'tart' is not installed. Install with: brew install cirruslabs/cli/tart"
    exit 1
fi

if [[ ! -f "$SSH_KEY" ]]; then
    echo "Error: SSH public key not found at $SSH_KEY"
    echo "Generate one with: ssh-keygen -t ed25519"
    exit 1
fi

# --- Derived names ---
REPO_URL="$1"
REPO_NAME=$(basename "$REPO_URL" .git)
VM_NAME="reproducer-${REPO_NAME}-$(date +%s)"

# --- Cleanup on failure ---
cleanup() {
    echo ""
    echo "Cleaning up VM '$VM_NAME'..."
    # Remove SSH config block
    if [[ -f ~/.ssh/config ]]; then
        sed -i '' "/^# --- $VM_NAME ---$/,/^# --- end $VM_NAME ---$/d" ~/.ssh/config 2>/dev/null || true
    fi
    # Remove host key
    ssh-keygen -R "$VM_IP" 2>/dev/null || true
    # Remove stale Gateway environment
    REMOTE_PROJECTS=~/Library/Caches/JetBrains/Toolbox/remote_projects.json
    if [[ -f "$REMOTE_PROJECTS" ]]; then
        python3 -c "
import json, sys
with open('$REMOTE_PROJECTS') as f: data = json.load(f)
data = [e for e in data if '$VM_IP' not in e.get('environmentId','')]
with open('$REMOTE_PROJECTS','w') as f: json.dump(data, f, indent=4)
" 2>/dev/null || true
    fi
    kill "$TART_PID" 2>/dev/null || true
    wait "$TART_PID" 2>/dev/null || true
    tart delete "$VM_NAME" 2>/dev/null || true
}

# --- Create and start VM ---
echo "==> Creating VM '$VM_NAME' from '$BASE_IMAGE'..."
tart clone "$BASE_IMAGE" "$VM_NAME"

echo "==> Starting VM (headless)..."
tart run "$VM_NAME" --no-graphics --dir=m2:"$HOME/.m2":ro &
TART_PID=$!

# If anything fails from here, clean up
trap cleanup ERR

# --- Wait for IP ---
echo "==> Waiting for VM IP..."
VM_IP=""
for i in $(seq 1 60); do
    VM_IP=$(tart ip "$VM_NAME" 2>/dev/null || true)
    if [[ -n "$VM_IP" ]]; then
        break
    fi
    sleep 1
done

if [[ -z "$VM_IP" ]]; then
    echo "Error: VM did not get an IP within 60 seconds"
    cleanup
    exit 1
fi
echo "    IP: $VM_IP"

# --- Wait for SSH ---
echo "==> Waiting for SSH..."
for i in $(seq 1 60); do
    if nc -z -w2 "$VM_IP" 22 2>/dev/null; then
        break
    fi
    sleep 1
done

# Give sshd a moment to fully initialize
sleep 2

# --- Register host key and SSH config (so Gateway can connect) ---
echo "==> Registering VM with SSH..."
ssh-keyscan -H "$VM_IP" >> ~/.ssh/known_hosts 2>/dev/null

SSH_PRIVATE_KEY="${SSH_KEY%.pub}"
cat >> ~/.ssh/config <<SSHCONF
# --- $VM_NAME ---
Host $VM_NAME
    HostName $VM_IP
    User $VM_USER
    IdentityFile $SSH_PRIVATE_KEY
    StrictHostKeyChecking no
# --- end $VM_NAME ---
SSHCONF

# --- Copy SSH key ---
echo "==> Copying SSH key..."
expect -c "
set timeout 30
spawn ssh-copy-id $SSH_OPTS -i $SSH_KEY $VM_USER@$VM_IP
expect {
    \"*assword:\" { send \"$VM_PASSWORD\r\"; exp_continue }
    \"*already exist*\" { }
    eof { }
}
" >/dev/null 2>&1

# --- Mount .m2 as overlay (host artifacts visible, writes stay in VM) ---
echo "==> Setting up .m2 overlay..."
ssh $SSH_OPTS "$VM_USER@$VM_IP" bash <<'REMOTE'
# Mount the virtiofs share from the host
sudo mkdir -p /mnt/m2-host
if sudo mount -t virtiofs com.apple.virtio-fs.automount /mnt/m2-host 2>/dev/null; then
    # Tart mounts shared dirs under a single virtiofs mount at this tag
    M2_LOWER="/mnt/m2-host/m2"
elif sudo mount -t virtiofs m2 /mnt/m2-host 2>/dev/null; then
    M2_LOWER="/mnt/m2-host"
else
    echo "Warning: Could not mount virtiofs share — .m2 overlay skipped"
    exit 0
fi

if [ -d "$M2_LOWER" ]; then
    mkdir -p /tmp/m2-upper /tmp/m2-work /home/admin/.m2
    sudo mount -t overlay overlay \
        -o "lowerdir=$M2_LOWER,upperdir=/tmp/m2-upper,workdir=/tmp/m2-work" \
        /home/admin/.m2
    echo ".m2 overlay mounted successfully"
else
    echo "Warning: Shared directory not found at $M2_LOWER — .m2 overlay skipped"
fi
REMOTE

# --- Install IDE backend ---
echo "==> Installing IntelliJ IDEA backend in VM (this may take a minute)..."
IDE_PATH=$(ssh $SSH_OPTS "$VM_USER@$VM_IP" bash <<'REMOTE'
# Get the latest IntelliJ IDEA Ultimate download URL for Linux aarch64
RELEASE_INFO=$(curl -s "https://data.services.jetbrains.com/products/releases?code=IIU&latest=true&type=release")
DOWNLOAD_URL=$(echo "$RELEASE_INFO" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for d in data['IIU'][0]['downloads'].values():
    if 'linuxARM64' in d.get('link', ''):
        print(d['link']); break
else:
    # Try the key directly
    arm = data['IIU'][0]['downloads'].get('linuxARM64', {})
    print(arm.get('link', ''))
")

if [ -z "$DOWNLOAD_URL" ]; then
    echo "ERROR: Could not find download URL" >&2
    exit 1
fi

BUILD=$(echo "$RELEASE_INFO" | python3 -c "import json,sys; print(json.load(sys.stdin)['IIU'][0]['build'])")
IDE_DIR="$HOME/.cache/JetBrains/RemoteDev/dist/IU-${BUILD}"

if [ -d "$IDE_DIR" ]; then
    echo "$IDE_DIR"
    exit 0
fi

mkdir -p "$HOME/.cache/JetBrains/RemoteDev/dist"
echo "Downloading IntelliJ IDEA backend..." >&2
curl -L "$DOWNLOAD_URL" 2>/dev/null | tar xz -C /tmp
EXTRACTED=$(ls -d /tmp/idea-IU-* 2>/dev/null | head -1)
mv "$EXTRACTED" "$IDE_DIR"
echo "$IDE_DIR"
REMOTE
)

if [[ -z "$IDE_PATH" || "$IDE_PATH" == *"ERROR"* ]]; then
    echo "Warning: Failed to install IDE backend. Gateway will prompt you to install manually."
    IDE_PATH=""
fi

# --- Clone repo ---
echo "==> Cloning $REPO_URL in VM..."
ssh $SSH_OPTS "$VM_USER@$VM_IP" "git clone '$REPO_URL' '/home/$VM_USER/$REPO_NAME'"

PROJECT_PATH="/home/$VM_USER/$REPO_NAME"

# --- Launch Gateway ---
echo "==> Launching JetBrains Gateway..."
ENCODED_PROJECT_PATH=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${PROJECT_PATH}'))")
if [[ -n "$IDE_PATH" ]]; then
    ENCODED_IDE_PATH=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${IDE_PATH}'))")
    open "jetbrains-gateway://connect#type=ssh&deploy=false&host=${VM_IP}&port=22&user=${VM_USER}&projectPath=${ENCODED_PROJECT_PATH}&idePath=${ENCODED_IDE_PATH}"
else
    open "jetbrains://gateway/ssh/environment?h=${VM_IP}&u=${VM_USER}&p=22&launchIde=true&ideHint=IU&projectHint=${ENCODED_PROJECT_PATH}"
fi

# --- Done ---
# Remove the ERR trap now that we've succeeded
trap - ERR

cat <<EOF

================================================================
VM is running: $VM_NAME (PID: $TART_PID)
SSH:            ssh $VM_NAME
Project:        $PROJECT_PATH

To stop and clean up when done:
  kill $TART_PID && tart delete $VM_NAME
  sed -i '' '/^# --- $VM_NAME ---$/,/^# --- end $VM_NAME ---$/d' ~/.ssh/config
  ssh-keygen -R $VM_IP
================================================================
EOF
